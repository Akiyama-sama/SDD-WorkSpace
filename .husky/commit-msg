#!/bin/sh

commit_msg_file="$1"

if [ -z "$commit_msg_file" ] || [ ! -f "$commit_msg_file" ]; then
  echo "错误: 未找到提交信息文件"
  exit 1
fi

commit_msg="$(cat "$commit_msg_file")"
regex='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,50}$'

if ! printf '%s' "$commit_msg" | grep -Eq "$regex"; then
  echo "错误: 提交信息不符合规范！"
  echo "规范格式: <type>(<scope>): <description>"
  echo "示例: feat(auth): add login feature"
  exit 1
fi
