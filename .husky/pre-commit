#!/bin/bash

# 读取提交信息文件
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 定义正则表达式 (符合 Conventional Commits)
# 格式: type(scope?): description
# type 包括: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
REGEX="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,50}"

if ! [[ "$COMMIT_MSG" =~ $REGEX ]]; then
  echo "错误: 提交信息不符合规范！"
  echo "规范格式: <type>(<scope>): <description>"
  echo "示例: feat(auth): add login feature"
  exit 1
fi